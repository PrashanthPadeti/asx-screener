# ─────────────────────────────────────────────────────────────
#  ASX Screener — Environment Variables
#  Copy to .env and fill in real values before running.
#  NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=asx_screener
POSTGRES_USER=asx_user
POSTGRES_PASSWORD=changeme_strong_password
DATABASE_URL=postgresql+asyncpg://asx_user:changeme_strong_password@localhost:5432/asx_screener
DATABASE_URL_SYNC=postgresql://asx_user:changeme_strong_password@localhost:5432/asx_screener

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300

# ── Elasticsearch ─────────────────────────────────────────────
ES_URL=http://localhost:9200
ES_INDEX_METRICS=asx_metrics

# ── JWT Auth ──────────────────────────────────────────────────
JWT_SECRET=change_me_to_64_char_random_string_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Stripe (payments) ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_PREMIUM_PRICE_ID=price_...

# ── Anthropic (Claude API) ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_CLASSIFY=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_CHAT=claude-sonnet-4-6

# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@asxscreener.com.au
EMAIL_FROM_NAME=ASX Screener

# ── AWS S3 (document storage) ─────────────────────────────────
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=ap-southeast-2
S3_BUCKET_ANNOUNCEMENTS=asx-screener-announcements
S3_BUCKET_REPORTS=asx-screener-reports

# ── Airflow ───────────────────────────────────────────────────
AIRFLOW_FERNET_KEY=change_me_run_python_c_from_cryptography_fernet_import_Fernet_print_Fernet_generate_key_decode
AIRFLOW_SECRET_KEY=change_me_random_32_chars

# ── External Data ─────────────────────────────────────────────
# Yahoo Finance — no key needed (yfinance library)
# ASX API — no key needed (public endpoints)

# Financial Modelling Prep (Phase 2 — optional)
FMP_API_KEY=

# ASIC Short Sales URL (public)
ASIC_SHORT_SALES_URL=https://asic.gov.au/regulatory-resources/markets/short-selling/short-position-reports-table/

# ── App Settings ──────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:3000
API_URL=http://localhost:8000

# Allowed hosts/origins (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1
ALLOWED_ORIGINS=http://localhost:3000

# ── Monitoring ────────────────────────────────────────────────
SENTRY_DSN=
POSTHOG_API_KEY=
