# ─────────────────────────────────────────────────────────────
#  ASX Screener — .gitignore
# ─────────────────────────────────────────────────────────────

# Environment & Secrets (NEVER commit these)
.env
.env.local
.env.production
.env.*.local
*.pem
*.key
secrets/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.eggs/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml
*.cover

# Node / Next.js
node_modules/
.next/
out/
.turbo/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# IDEs
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Docker
docker-compose.override.yml

# Logs
logs/
*.log

# Data files (large CSVs, parquet — use S3 instead)
data/
*.csv
*.parquet
*.pkl

# Airflow
airflow/logs/
airflow/plugins/__pycache__/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# OS
.DS_Store
ehthumbs.db
Desktop.ini
