# ── Copy this to .env and fill in real values ──────────────────────────────────

# App
ENVIRONMENT=production
DEBUG=False

# Database
DATABASE_URL=postgresql+asyncpg://asx_user:CHANGE_ME@localhost:5432/asx_screener
DATABASE_URL_SYNC=postgresql://asx_user:CHANGE_ME@localhost:5432/asx_screener

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=change-this-to-a-random-64-char-string

# Frontend base URL (used in Stripe redirect URLs and emails)
FRONTEND_URL=https://asxscreener.com.au

# ── Stripe ─────────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — get from https://dashboard.stripe.com/products
# Individual plans
STRIPE_PRO_MONTHLY=price_...
STRIPE_PRO_YEARLY=price_...
STRIPE_PREMIUM_MONTHLY=price_...
STRIPE_PREMIUM_YEARLY=price_...

# Enterprise Pro
STRIPE_ENT_PRO_5_MONTHLY=price_...
STRIPE_ENT_PRO_5_YEARLY=price_...
STRIPE_ENT_PRO_10_MONTHLY=price_...
STRIPE_ENT_PRO_10_YEARLY=price_...

# Enterprise Premium
STRIPE_ENT_PREM_5_MONTHLY=price_...
STRIPE_ENT_PREM_5_YEARLY=price_...
STRIPE_ENT_PREM_10_MONTHLY=price_...
STRIPE_ENT_PREM_10_YEARLY=price_...

# ── Email (Resend) ─────────────────────────────────────────────────────────────
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@asxscreener.com.au
SUPPORT_EMAIL=asxscreener@gmail.com
ADMIN_EMAILS=asxscreener@gmail.com

# ── Market Data ────────────────────────────────────────────────────────────────
EODHD_API_KEY=...
ALPHA_VANTAGE_API_KEY=...

# ── AI ─────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── AWS S3 ─────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_S3_BUCKET=asx-screener-docs
AWS_REGION=ap-southeast-2
